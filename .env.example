# ── Model provider ────────────────────────────────────────────────────────────
# Which LLM backend to use. Accepted values: gemini (default) | groq | vertex
MODEL_PROVIDER=gemini

# ── Gemini (default provider) ─────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key-here
# Override the default Gemini model (optional)
GEMINI_MODEL=gemma-3-27b-it

# ── Groq (alternative provider) ───────────────────────────────────────────────
# Set MODEL_PROVIDER=groq and supply this key to switch providers
GROQ_API_KEY=your-groq-api-key-here
# Override the default Groq model (optional)
GROQ_MODEL=groq/qwen/qwen3-32b

# ── Vertex AI (alternative provider) ──────────────────────────────────────────
# Set MODEL_PROVIDER=vertex to use Vertex AI with Application Default Credentials.
#
# One-time machine setup (requires gcloud CLI — `brew install --cask google-cloud-sdk`):
#   gcloud auth application-default login
#   gcloud config set project YOUR_PROJECT_ID
#
# This writes credentials to ~/.config/gcloud/application_default_credentials.json,
# which the Google Gen AI SDK picks up automatically. No API key needed.
#
# See: https://cloud.google.com/docs/authentication/provide-credentials-adc
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Override the default Vertex model (optional)
VERTEX_MODEL=gemini-2.5-flash-lite

# ── GCP deployment tutorial ──────────────────────────────────────────────────
# Used by src/tutorials/deploy_gcp.
STAGING_BUCKET=gs://your-agent-staging-bucket
CLOUD_RUN_SERVICE_NAME=roll-die-agent
CLOUD_RUN_SERVICE_URL=https://your-cloud-run-service-url
CLOUD_RUN_AUTH=true
ADK_APP_NAME=roll_die
ADK_USER_ID=notebook-user
ADK_PROMPT=Roll a 6-sided die 3 times
AGENT_ENGINE_ID=projects/your-project-number/locations/us-central1/reasoningEngines/your-engine-id

# ── MCP agent ─────────────────────────────────────────────────────────────────
# URL of the MCP filesystem server (tutorials/mcp_agent)
MCP_SERVER_URL=http://127.0.0.1:9001/sse
